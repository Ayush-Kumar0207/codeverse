{
  "name": "client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "npm run test:unit",
    "test:unit": "vitest run --coverage",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "algo:audit": "node scripts/audit_algo_catalog.cjs",
    "algo:ollama": "node scripts/run_ollama_algo_pipeline.js",
    "algo:ollama:continuous": "node scripts/run_ollama_algo_pipeline.js --continuous --batch=6 --concurrency=2 --interval-ms=8000",
    "algo:ollama:story-dryruns": "node scripts/run_ollama_algo_pipeline.js --continuous --story-dry-run-only --batch=8 --concurrency=2 --interval-ms=4000 --request-timeout-ms=150000 --num-predict=2200 --temperature=0.12 --attempts=3 --fail-cooldown-min=120",
    "algo:ollama:turbo": "node scripts/run_ollama_algo_pipeline.js --continuous --batch=10 --concurrency=4 --interval-ms=2000 --request-timeout-ms=120000 --num-predict=2800 --temperature=0.06 --attempts=2",
    "algo:ollama:ultra": "node scripts/run_ollama_algo_pipeline.js --continuous --batch=12 --concurrency=5 --interval-ms=1500 --request-timeout-ms=120000 --num-predict=2400 --temperature=0.05 --attempts=2",
    "algo:ollama:bullet": "node scripts/run_ollama_algo_pipeline.js --continuous --batch=16 --concurrency=6 --interval-ms=800 --request-timeout-ms=90000 --num-predict=2000 --temperature=0.04 --attempts=2 --fail-cooldown-min=180 --no-prioritize-easy",
    "algo:ollama:balanced": "node scripts/run_ollama_algo_pipeline.js --continuous --batch=14 --concurrency=4 --interval-ms=1200 --request-timeout-ms=120000 --num-predict=2400 --temperature=0.05 --attempts=2 --fail-cooldown-min=120",
    "algo:audit:3d": "node scripts/audit_cinematic_visualizers.cjs",
    "app:audit": "node scripts/audit_app_routes.cjs",
    "collab:audit": "node scripts/audit_collaboration.cjs",
    "visual:audit": "node scripts/audit_visual_system.cjs",
    "cpp:format": "node scripts/format_cpp_catalog.cjs",
    "cpp:audit": "node scripts/audit_cpp_catalog.cjs",
    "release:audit": "npm run app:audit && npm run visual:audit && npm run collab:audit && npm run algo:audit && npm run algo:audit:3d && npm run cpp:audit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@types/three": "^0.185.0",
    "axios": "^1.10.0",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^11.15.0",
    "github-markdown-css": "^5.8.1",
    "lodash.debounce": "^4.0.8",
    "lucide-react": "^0.515.0",
    "next": "^15.3.8",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.9",
    "remark-gfm": "^4.0.1",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^2.6.1",
    "tailwind-scrollbar-hide": "^4.0.0",
    "three": "^0.185.1",
    "tw-animate-css": "^1.4.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.1.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.4",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.4.21",
    "eslint": "^9",
    "eslint-config-next": "^15.3.8",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "description": "The Next.js client for CodeVerse, a collaborative IDE and interactive algorithm-learning platform.",
  "keywords": [
    "collaborative-ide",
    "nextjs",
    "monaco-editor",
    "threejs",
    "algorithms"
  ],
  "author": "Ayush Kumar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ayush-Kumar0207/codeverse.git",
    "directory": "client"
  },
  "homepage": "https://codeverse-rho.vercel.app",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "overrides": {
    "sharp": "^0.35.0",
    "postcss": "^8.5.6",
    "dompurify": "^3.4.12"
  }
}
